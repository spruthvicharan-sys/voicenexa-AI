# ── Groq (LLM) ───────────────────────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model options (all free on Groq):
#   llama-3.3-70b-versatile  ← recommended, best quality
#   llama3-8b-8192           ← fastest, lightweight
#   mixtral-8x7b-32768       ← great for long context
#   gemma2-9b-it             ← Google's model
GROQ_MODEL=llama-3.3-70b-versatile

# ── ElevenLabs (TTS) ─────────────────────────────────
# Get free key at: https://elevenlabs.io (10,000 chars/month free)
ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Voice ID — default is Rachel (calm, natural)
# Find more at: https://elevenlabs.io/voice-library
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Whisper (STT) ─────────────────────────────────────
# Runs locally — NO key needed
# Options: tiny | base | small | medium | large
WHISPER_MODEL=base

# ── Server ────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
